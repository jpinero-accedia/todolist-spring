# ==========================================
# ☕ Compilados genéricos de Java
# ==========================================
*.class
*.jar
*.war
*.ear

# ==========================================
# 🐘 Archivos de Gradle
# ==========================================
.gradle/
build/
# IMPORTANTE: No ignoramos el wrapper para que los alumnos puedan ejecutar ./gradlew
!gradle/wrapper/gradle-wrapper.jar
# Excepciones por si hay carpetas de código que se llamen "build"
!**/src/main/**/build/
!**/src/test/**/build/

# ==========================================
# 🪶 Archivos de Maven
# ==========================================
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
# IMPORTANTE: No ignoramos el wrapper para que los alumnos puedan ejecutar ./mvnw
!.mvn/wrapper/maven-wrapper.jar

# ==========================================
# 📝 Archivos de Logs (Para tu US-03)
# ==========================================
*.log
logs/

# ==========================================
# 💻 Entornos de Desarrollo (IDEs)
# ==========================================
# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# Eclipse / Spring Tool Suite
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache/
bin/

# VS Code / GitHub Codespaces
.vscode/

# ==========================================
# 🖥️ Archivos del Sistema Operativo
# ==========================================
# Mac
.DS_Store
# Windows
Thumbs.db
